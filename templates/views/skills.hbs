<!DOCTYPE html>
<html lang="en">
{{>header}}

<body>
    {{>navbar}}
    <div class="container">
        <h3 class="text-center my-4" id="skillhead"><i class="fas fa-laptop-code fa-lg"></i> My Skills</h3>
        <div class="row">
            <div class="col-12 col-md-4 skillscard">
                <div class="card mycrd" style="background-color: black;">
                    <img src="/images/cpp.jpeg" class="card-img-top skillspic" alt="Not Found">
                    <div class="card-body">
                        <h5 class="card-title">C++</h5>
                        <p class="card-text">
                            <div class="progress">
                                <div class="progress-bar" role="progressbar" style="width: 80%;" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100">80%</div>
                            </div>
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4 skillscard">
                <div class="card mycrd" style="background-color: black;">
                    <img src="/images/python.png" class="card-img-top skillspic" alt="Not Found">
                    <div class="card-body">
                        <h5 class="card-title">Python</h5>
                        <p class="card-text">
                            <div class="progress">
                                <div class="progress-bar" role="progressbar" style="width: 75%;" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100">60%</div>
                            </div>
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4 skillscard">
                <div class="card mycrd" style="background-color: black;">
                    <img src="/images/htmlcss.png" class="card-img-top skillspic" alt="Not Found">
                    <div class="card-body">
                        <h5 class="card-title">HTML & CSS</h5>
                        <p class="card-text">
                            <div class="progress">
                                <div class="progress-bar" role="progressbar" style="width: 100%;" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100">90%</div>
                            </div>
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4 skillscard">
                <div class="card mycrd" style="background-color: black;">
                    <img src="/images/javascript.png" class="card-img-top skillspic" alt="Not Found">
                    <div class="card-body">
                        <h5 class="card-title">Javascript</h5>
                        <p class="card-text">
                            <div class="progress">
                                <div class="progress-bar" role="progressbar" style="width: 80%;" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100">80%</div>
                            </div>
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4 skillscard">
                <div class="card mycrd" style="background-color: black;">
                    <img src="/images/react.png" class="card-img-top skillspic" alt="Not Found">
                    <div class="card-body">
                        <h5 class="card-title">ReactJs</h5>
                        <p class="card-text">
                            <div class="progress">
                                <div class="progress-bar" role="progressbar" style="width: 75%;" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100">70%</div>
                            </div>
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4 skillscard">
                <div class="card mycrd" style="background-color: black;">
                    <img src="/images/node.png" class="card-img-top skillspic" alt="Not Found">
                    <div class="card-body">
                        <h5 class="card-title">NodeJs</h5>
                        <p class="card-text">
                            <div class="progress">
                                <div class="progress-bar" role="progressbar" style="width: 80%;" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100">60%</div>
                            </div>
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4 skillscard">
                <div class="card mycrd" style="background-color: black;">
                    <img src="/images/ds.png" class="card-img-top skillspic" alt="Not Found">
                    <div class="card-body">
                        <h5 class="card-title">Data Structure</h5>
                        <p class="card-text">
                            <div class="progress">
                                <div class="progress-bar" role="progressbar" style="width: 60%;" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100">65%</div>
                            </div>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {{>footer}}
</body>

</html>